# Supabase — get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 — get from Cloudflare Dashboard > R2 > Manage R2 API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=gis-data-lenga-maps

# Web3Forms — powers email notifications (contact form + manual payment alerts)
# Free key from https://web3forms.com — enter lengamaps@gmail.com as the destination
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# Admin allow-list — comma-separated emails that can access /admin/* and
# approve/reject manual payments. Server-side only (no NEXT_PUBLIC_ prefix).
ADMIN_EMAILS=lengamaps@gmail.com,cmulenga672@gmail.com

# CallMeBot WhatsApp — optional: sends manual-payment alerts to your WhatsApp.
# One-time setup:
#   1. Add +34 644 59 71 67 to your contacts
#   2. From the phone below, WhatsApp that contact: "I allow callmebot to send me messages to this number"
#   3. You receive an API key reply — paste it below
# Leave blank to disable WhatsApp notifications (email still fires).
CALLMEBOT_WHATSAPP_PHONE=260965699359
CALLMEBOT_WHATSAPP_APIKEY=
